##########################################################################################################################################################
#                                                                                                                                                        #
#                                                                                                                                                        #
#                                                                   NETWORKING DATA                                                                      #
#                                                                                                                                                        #
#                                                                                                                                                        #
##########################################################################################################################################################

data "terraform_remote_state" "vpc" {
  backend = "s3"

  config = {
    bucket = "aws-remote-backend-tf"
    key = "networking/terraform.tfstate"
    region = "eu-west-3"
  }
}

##########################################################################################################################################################
#                                                                                                                                                        #
#                                                                                                                                                        #
#                                                                      STORAGE DATA                                                                      #
#                                                                                                                                                        #
#                                                                                                                                                        #
##########################################################################################################################################################

data "terraform_remote_state" "efs" {
  backend = "s3"

  config = {
    bucket = "aws-remote-backend-tf"
    key = "storage/terraform.tfstate"
    region = "eu-west-3"
  }
}